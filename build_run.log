+            </div>
+          </div>
+          
+          {/* Progress Bar */}
+          <div className="mt-4">
+            <div className="flex items-center justify-between text-sm mb-2">
+              <span className="text-gray-600">Progress</span>
+              <span className="text-gray-900 font-medium">{completedCount} / {totalCount} decisions</span>
